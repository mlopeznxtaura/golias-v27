# Non-secret Golias runtime config (safe in git). Copy to /opt/golias/config.env on GPU.
# All credentials come from IBM Secrets Manager — never put tokens here.

IBM_SECRETS_MANAGER_URL=
IBM_SECRETS_MANAGER_REGION=us-south

# Paths (no secrets)
GOLIAS_BASE=/opt/golias-v27
GOLIAS_CKPT=/opt/golias-v27/goliasv28.pt
GOLIAS_LOG=/opt/golias-v27/train_hybrid.log
PORT=8080
